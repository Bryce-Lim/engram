#!/usr/bin/env python3
"""Executable entry point for the Engram CLI.

Adds the project root to sys.path so ``engram`` runs from a checkout without
installation, then delegates to :func:`engram.cli.main`.
"""

import os
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
_ROOT = os.path.dirname(_HERE)
if _ROOT not in sys.path:
    sys.path.insert(0, _ROOT)

from engram.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
